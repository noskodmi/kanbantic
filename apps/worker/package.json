{
  "name": "@kanbantic/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir=dist",
    "dev": "wrangler dev",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 execute kanbantic-indexer --local --file migrations/0001_initial.sql",
    "migrate:remote": "wrangler d1 execute kanbantic-indexer --remote --file migrations/0001_initial.sql"
  },
  "dependencies": {
    "@kanbantic/shared": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.34",
    "@cloudflare/workers-types": "^4.20241224.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
